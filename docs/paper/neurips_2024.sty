%% neurips_2024.sty — faithful reconstruction of the NeurIPS 2024 style.
%% Reproduces the NeurIPS layout (single column, Times, 5.5in x 9in text block,
%% centred ruled abstract, NeurIPS title/author block). Interface matches the
%% official package: \usepackage[preprint]{neurips_2024} (also [final], [nonatbib]).
%% For camera-ready/submission, drop in the official neurips_2024.sty — same interface.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/05/01 NeurIPS 2024 (faithful reconstruction)]

\newif\if@nipsfinal\@nipsfinalfalse
\newif\if@nipspreprint\@nipspreprintfalse
\newif\if@nipsnatbib\@nipsnatbibtrue
\DeclareOption{final}{\@nipsfinaltrue}
\DeclareOption{preprint}{\@nipspreprinttrue}
\DeclareOption{nonatbib}{\@nipsnatbibfalse}
\ProcessOptions\relax

% --- fonts: Times for text and math (NeurIPS look) -------------------------
\RequirePackage{mathptmx}
\renewcommand{\rmdefault}{ptm}

% --- page geometry: 5.5in x 9in text block on US letter --------------------
\RequirePackage[letterpaper,left=1.5in,right=1.5in,top=1in,bottom=1in]{geometry}
\setlength{\parindent}{0pt}
\setlength{\parskip}{5.5pt plus 2pt minus 1pt}
\setlength{\textfloatsep}{8pt plus 2pt minus 2pt}
\widowpenalty=10000
\clubpenalty=10000

% --- natbib (optional, on by default like the official) --------------------
\if@nipsnatbib
  \RequirePackage{natbib}
  \renewcommand{\bibsection}{\subsubsection*{\refname}}
  \setlength{\bibsep}{1.5pt}
\fi

% --- section headings (NeurIPS sizing; manual \@startsection like the official
%     style, so section \label{} anchors correctly without titlesec) ----------
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.0ex \@plus -0.5ex \@minus -0.2ex}{1.0ex \@plus 0.2ex}%
  {\normalfont\large\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-1.8ex \@plus -0.5ex \@minus -0.2ex}{0.7ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}
\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-1.5ex \@plus -0.5ex \@minus -0.2ex}{0.5ex \@plus 0.2ex}%
  {\normalfont\normalsize\bfseries}}

% --- captions: small, as in NeurIPS ----------------------------------------
\RequirePackage[font=small,labelfont=bf,skip=4pt]{caption}

% --- title / author block --------------------------------------------------
\renewcommand{\@maketitle}{%
  \newpage\null\vskip 0.3in%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 0.25in%
    {\large \@author \par}%
    \vskip 0.1in%
  \end{center}%
  \par\vskip 0.2in%
}

% --- abstract: centred, ruled, narrower (NeurIPS) --------------------------
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.4ex}%
  \begin{center}\rule{\textwidth}{0.4pt}\end{center}%
  \vspace{-0.6ex}%
  \begingroup\leftskip=0.4in\rightskip=0.4in\small%
}{%
  \par\endgroup%
  \vspace{-0.4ex}%
  \begin{center}\rule{\textwidth}{0.4pt}\end{center}%
  \vspace{0.3ex}%
}

% --- preprint / submission footer banner -----------------------------------
\if@nipsfinal\else\if@nipspreprint\else
  % review mode: anonymous banner (no line numbers in this reconstruction)
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}\fancyhf{}\renewcommand{\headrulewidth}{0pt}
  \cfoot{\small Submitted to NeurIPS 2024. Do not distribute. \quad \thepage}
\fi\fi

\endinput
